{
  "name": "workpot",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf build .svelte-kit src-tauri/gen",
    "clean:all": "rm -rf build .svelte-kit src-tauri/gen node_modules package-lock.json pnpm-lock.yaml",
    "dev": "vite dev",
    "build": "node scripts/vite-build.mjs",
    "tauri:build": "node scripts/vite-build.mjs && tauri build --config src-tauri/tauri.ci-build.json",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "lint:sarif": "eslint . --format .github/eslint-sarif/sarif.cjs --output-file eslint-results.sarif",
    "test": "vitest run --project=unit",
    "test:coverage": "vitest run --coverage --project=unit",
    "test:storybook": "vitest --project=storybook",
    "test:storybook:run": "vitest run --project=storybook",
    "test:storybook:coverage": "vitest run --project=storybook --coverage",
    "tauri": "tauri",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.28.0",
    "jschardet": "^3.1.4",
    "lodash": "^4.17.21",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/svelte-vite": "^10.4.3",
    "@storybook/sveltekit": "^10.4.3",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.1",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-storybook": "^10.4.3",
    "eslint-plugin-svelte": "^3.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.2.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.33.0",
    "utf8": "^3.0.0",
    "vite": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.34.3"
}
